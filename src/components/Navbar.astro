---
import { clinic } from '../data/clinic.js';
import ContactCtaContent from './ContactCtaContent.astro';
---

<nav class="navbar" aria-label="Navegación principal">
  <div class="navbar-inner">
    <a class="logo" href="#inicio" aria-label="Cavagna y Musacchio, ir al inicio">
      <h2>{clinic.name}</h2>
      <span>{clinic.tagline}</span>
    </a>
    <ul id="mainNav">
      {clinic.navigationLinks.map((link) => (
        <li><a href={link.href}>{link.label}</a></li>
      ))}
    </ul>
    <a href="#" class="btn-nav nav-booking cta-primary contact-cta"><ContactCtaContent label="Agendar una consulta" /></a>
    <button class="mobile-menu-toggle" type="button" aria-expanded="false" aria-controls="mainNav" aria-label="Abrir menú">
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>
