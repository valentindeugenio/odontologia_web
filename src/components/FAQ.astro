---
import { faqItems } from '../data/faq.js';
import ContactCtaContent from './ContactCtaContent.astro';
---

<section class="faq" id="faq">
  <div class="container faq-section-container">
    <header class="faq-heading">
      <div>
        <span class="section-tag">PREGUNTAS FRECUENTES</span>
        <h2>Información clara para decidir con confianza</h2>
      </div>
      <p>
        Respondemos las dudas más habituales para que sepas qué esperar antes, durante
        y después de tu tratamiento.
      </p>
    </header>

    <div class="faq-container">
      {faqItems.map((item, index) => (
        <div class="faq-item">
          <button class="faq-question" type="button" aria-expanded="false">
            <span class="faq-number" aria-hidden="true">{String(index + 1).padStart(2, '0')}</span>
            <span class="faq-question-text">{item.question}</span>
            <span class="faq-toggle-icon" aria-hidden="true">
              <span></span>
              <span></span>
            </span>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-inner">
              <p>{item.answer}</p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <div class="faq-cta">
      <p>¿Todavía tenés alguna duda sobre tu caso?</p>
      <button class="faq-cta-button abrir-modal cta-secondary contact-cta" type="button">
        <ContactCtaContent label="Resolver mi consulta" />
      </button>
    </div>
  </div>
</section>
