---
import { testimonials } from '../data/testimonials.js';
---

<section class="reviews" id="testimonios">
  <div class="container reviews-container">
    <header class="reviews-heading">
      <div>
        <span class="section-tag">OPINIONES</span>
        <h2>La confianza de quienes ya nos eligieron</h2>
      </div>
      <p>
        Experiencias reales que reflejan nuestra forma de trabajar: escucha, claridad y
        atención personalizada en cada consulta.
      </p>
    </header>

    <div class="review-grid">
      {testimonials.map((testimonial) => (
        <article class="review-card">
          <div class="review-card-top">
            <svg class="review-quote-icon" viewBox="0 0 32 32" aria-hidden="true">
              <path d="M7.5 17.5h7V26h-9v-7.2C5.5 11 9 7.2 14 5l1.2 2.7c-3.7 1.9-5.8 4.7-6.2 8.1h5.5M22 17.5h7V26h-9v-7.2C20 11 23.5 7.2 28.5 5l1.2 2.7c-3.7 1.9-5.8 4.7-6.2 8.1H29"></path>
            </svg>

            <div class="review-rating" aria-label={`${testimonial.rating} de 5 estrellas`}>
              <span class="review-rating-value">{testimonial.rating}.0</span>
              <span class="review-stars" aria-hidden="true">
                {Array.from({ length: testimonial.rating }).map(() => (
                  <svg viewBox="0 0 20 20">
                    <path d="m10 2.4 2.2 4.5 5 .7-3.6 3.5.9 5-4.5-2.4-4.5 2.4.9-5-3.6-3.5 5-.7L10 2.4Z"></path>
                  </svg>
                ))}
              </span>
            </div>
          </div>

          <blockquote>
            <p>“{testimonial.quote}”</p>
          </blockquote>

          <footer class="review-author">
            <span class="review-avatar" aria-hidden="true">
              <svg viewBox="0 0 24 24">
                <path d="M12 12a4 4 0 1 0 0-8 4 4 0 0 0 0 8Zm7 8c0-3.3-3.1-6-7-6s-7 2.7-7 6"></path>
              </svg>
            </span>
            <span>
              <strong>{testimonial.author}</strong>
              <small>
                <svg viewBox="0 0 20 20" aria-hidden="true">
                  <path d="m10 2 2 1.5 2.5-.2.8 2.4 2.2 1.3-.8 2.4.8 2.4-2.2 1.3-.8 2.4-2.5-.2-2 1.5-2-1.5-2.5.2-.8-2.4-2.2-1.3.8-2.4L2.5 7l2.2-1.3.8-2.4 2.5.2L10 2Zm-2.8 8 1.8 1.8 3.8-4"></path>
                </svg>
                {testimonial.source}
              </small>
            </span>
          </footer>
        </article>
      ))}
    </div>

    <div class="reviews-cta">
      <p>Tu bienestar también puede empezar con una buena primera consulta.</p>
      <button class="reviews-cta-button abrir-modal" type="button">
        Agendar una consulta
        <svg viewBox="0 0 20 20" aria-hidden="true">
          <path d="M4 10h11M11 6l4 4-4 4"></path>
        </svg>
      </button>
    </div>
  </div>
</section>
