<dialog class="profile-dialog" id="professionalProfile" aria-labelledby="profileName">
  <button class="profile-close" type="button" aria-label="Cerrar perfil">×</button>
  <div class="profile-dialog-grid">
    <img id="profileImage" src="" alt="" />
    <div class="profile-dialog-content">
      <span class="section-tag">ACERCA DE MÍ</span>
      <h2 id="profileName"></h2>
      <p class="profile-specialty" id="profileSpecialty"></p>
      <div class="profile-years"><strong id="profileYears"></strong><span>de experiencia*</span></div>
      <p id="profileBio"></p>
      <ul class="profile-highlights" id="profileHighlights"></ul>
      <button class="btn-nav abrir-modal profile-booking cta-primary" type="button">Agendar con este profesional</button>
      <small>*Información demostrativa pendiente de confirmación.</small>
    </div>
  </div>
</dialog>

<div class="modal" id="consultaModal">
  <div class="modal-box">
    <div class="modal-progress" aria-hidden="true">
      <div class="modal-progress-bar" id="modalProgress"></div>
    </div>
    <button class="cerrar-modal" id="cerrarModal" type="button">
      <svg viewBox="0 0 20 20" aria-hidden="true">
        <path d="m5 5 10 10M15 5 5 15"></path>
      </svg>
    </button>

    <div id="step1">
      <header class="modal-heading">
        <span class="modal-eyebrow">CONSULTA PERSONALIZADA</span>
        <h2>¿Cómo podemos ayudarte?</h2>
        <p>Elegí una opción para que podamos orientarte de forma más precisa.</p>
      </header>

      <div class="tratamientos-grid">
        <div class="tratamiento-card tratamiento-card-featured" data-tratamiento="Implantes Dentales">
          <div class="icono">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 3.2c-2.1 0-2.8-1-4.7-1C4.8 2.2 3 4.4 3 7.1c0 2.2 1.2 3.7 1.8 5.5.8 2.3.8 6.8 3.1 8 2.2 1.1 2-4.7 4.1-4.7s1.9 5.8 4.1 4.7c2.3-1.2 2.3-5.7 3.1-8 .6-1.8 1.8-3.3 1.8-5.5 0-2.7-1.8-4.9-4.3-4.9-1.9 0-2.6 1-4.7 1Z"></path>
            </svg>
          </div>
          <div class="card-info">
            <span>Opción destacada</span>
            <h3>Implantes Dentales</h3>
            <p>Recuperá función y estética con una evaluación personalizada.</p>
          </div>
          <svg class="card-arrow" viewBox="0 0 20 20" aria-hidden="true">
            <path d="M4 10h11M11 6l4 4-4 4"></path>
          </svg>
        </div>

        <div class="tratamiento-card" data-tratamiento="Estética Dental">
          <div class="icono">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="m12 2 1.6 5.2L19 9l-5.4 1.8L12 16l-1.6-5.2L5 9l5.4-1.8L12 2Zm6.5 13 .7 2.3 2.3.7-2.3.7-.7 2.3-.7-2.3-2.3-.7 2.3-.7.7-2.3Z"></path>
            </svg>
          </div>
          <div class="card-info">
            <h3>Estética Dental</h3>
            <p>Tratamientos sutiles para una sonrisa armónica y natural.</p>
          </div>
          <svg class="card-arrow" viewBox="0 0 20 20" aria-hidden="true">
            <path d="M4 10h11M11 6l4 4-4 4"></path>
          </svg>
        </div>

        <div class="tratamiento-card" data-tratamiento="Limpieza y Control">
          <div class="icono">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 3 5 6v5c0 4.6 2.9 8.1 7 10 4.1-1.9 7-5.4 7-10V6l-7-3Zm-3 8 2 2 4-4"></path>
            </svg>
          </div>
          <div class="card-info">
            <h3>Limpieza y Control</h3>
            <p>Prevención profesional para mantener tu salud bucal.</p>
          </div>
          <svg class="card-arrow" viewBox="0 0 20 20" aria-hidden="true">
            <path d="M4 10h11M11 6l4 4-4 4"></path>
          </svg>
        </div>

        <div class="tratamiento-card" data-tratamiento="Agendar Consulta">
          <div class="icono">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M6 3v3m12-3v3M4 9h16M5 5h14a1 1 0 0 1 1 1v13a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1Zm3 8h3m2 0h3m-8 3h3"></path>
            </svg>
          </div>
          <div class="card-info">
            <h3>Agendar Consulta</h3>
            <p>Contanos qué necesitás y coordinamos el próximo paso.</p>
          </div>
          <svg class="card-arrow" viewBox="0 0 20 20" aria-hidden="true">
            <path d="M4 10h11M11 6l4 4-4 4"></path>
          </svg>
        </div>
      </div>

      <div class="modal-trust">
        <span>
          <svg viewBox="0 0 20 20" aria-hidden="true">
            <path d="m10 2 6 2.6v4.3c0 4-2.4 7.2-6 9.1-3.6-1.9-6-5.1-6-9.1V4.6L10 2Zm-2.5 7.7 1.7 1.7 3.5-3.6"></path>
          </svg>
          Atención personalizada
        </span>
        <span>Sin compromiso</span>
      </div>
    </div>

    <div id="step2" style="display:none;">
      <button class="volver" id="volverStep" type="button">
        <svg viewBox="0 0 20 20" aria-hidden="true">
          <path d="M16 10H5m4-4-4 4 4 4"></path>
        </svg>
        Volver
      </button>

      <div class="modal-step-heading">
        <span class="modal-eyebrow">ÚLTIMO PASO</span>
        <h2 id="tituloTratamiento"></h2>
        <p id="descripcionTratamiento"></p>
      </div>

      <form class="modal-form" novalidate>
        <div class="modal-field">
          <label class="campo-label" for="nombrePaciente">Nombre</label>
          <input id="nombrePaciente" name="nombre" type="text" placeholder="¿Cómo te llamás?" autocomplete="name" />
          <p class="error" id="errorNombre"></p>
        </div>

        <div class="modal-field">
          <label class="campo-label" for="telefonoPaciente">Teléfono</label>
          <input id="telefonoPaciente" name="telefono" type="tel" placeholder="Tu número de contacto" autocomplete="tel" inputmode="tel" />
          <p class="error" id="errorTelefono"></p>
        </div>

        <fieldset class="modal-field coverage-field">
          <legend class="campo-label">Cobertura</legend>
          <div class="coverage-options">
            <label class="coverage-option">
              <input type="radio" name="cobertura" value="OSDE" />
              <span class="coverage-control">
                <span class="coverage-logo">
                  <img src="/images/osde-logo.svg" alt="OSDE" />
                </span>
                <span>OSDE</span>
              </span>
            </label>

            <label class="coverage-option">
              <input type="radio" name="cobertura" value="Particular" checked />
              <span class="coverage-control">
                <span class="coverage-particular-icon" aria-hidden="true">
                  <svg viewBox="0 0 20 20">
                    <path d="M10 3.2a3.1 3.1 0 1 1 0 6.2 3.1 3.1 0 0 1 0-6.2Zm-5.2 13c.5-2.8 2.4-4.4 5.2-4.4s4.7 1.6 5.2 4.4"></path>
                  </svg>
                </span>
                <span>Particular</span>
              </span>
            </label>
          </div>
        </fieldset>

        <div class="modal-field">
          <label class="campo-label" for="tratamientoSeleccionado">Tratamiento</label>
          <input id="tratamientoSeleccionado" name="tratamiento" type="text" readonly />
        </div>

        <div class="modal-field">
          <label class="campo-label" for="mensajePaciente">
            Comentario
            <span>Opcional</span>
          </label>
          <textarea id="mensajePaciente" name="comentario" placeholder="Contanos brevemente qué necesitás."></textarea>
          <p class="error" id="errorInformacion"></p>
        </div>

        <button class="modal-turno cta-primary" id="enviarFormulario" type="button">
          Continuar por WhatsApp
          <svg viewBox="0 0 20 20" aria-hidden="true">
            <path d="M4 10h11M11 6l4 4-4 4"></path>
          </svg>
        </button>
        <p class="modal-form-note">Te vamos a contactar por WhatsApp para continuar.</p>
      </form>
    </div>
  </div>
</div>
