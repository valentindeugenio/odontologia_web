---
import { clinic } from '../data/clinic.js';
---

<section class="office" id="consultorio">
  <div class="container">
    <div class="office-heading">
      <div>
        <span class="section-tag">CONSULTORIO EN CABA</span>
        <h2>Dirección y datos de atención</h2>
      </div>
      <p>Estamos en una ubicación céntrica de la Ciudad de Buenos Aires. Podés abrir el mapa, llamarnos o escribirnos directamente.</p>
    </div>
    <div class="office-layout">
      <div class="map-wrapper">
        <iframe title="Mapa del consultorio en Av. Santa Fe 3069, CABA" src="https://www.google.com/maps?q=Av.%20Santa%20Fe%203069%2C%20CABA&output=embed" loading="lazy" referrerpolicy="no-referrer-when-downgrade" allowfullscreen></iframe>
      </div>
      <div class="contact-grid">
        <article class="contact-card">
          <span class="contact-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24">
              <path d="M20 10c0 5-8 11-8 11S4 15 4 10a8 8 0 1 1 16 0Z"></path>
              <circle cx="12" cy="10" r="2.5"></circle>
            </svg>
          </span>
          <div class="contact-card-content">
            <h3>Dirección</h3>
            <p>{clinic.address}, {clinic.city}</p>
          </div>
        </article>

        <article class="contact-card">
          <span class="contact-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24">
              <circle cx="12" cy="12" r="9"></circle>
              <path d="M12 7v5l3.2 2"></path>
            </svg>
          </span>
          <div class="contact-card-content">
            <h3>Horario de atención</h3>
            <p>{clinic.openingHours} · {clinic.openingHoursDetail}</p>
          </div>
        </article>

        <a class="contact-card" href={clinic.whatsappLink} target="_blank" rel="noopener noreferrer">
          <span class="contact-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24">
              <path d="M20 11.5a8 8 0 0 1-11.8 7l-4.2 1.2 1.2-4A8 8 0 1 1 20 11.5Z"></path>
              <path d="M8.7 8.2c.4 3.3 2.1 5 5.4 5.5"></path>
            </svg>
          </span>
          <div class="contact-card-content">
            <h3>WhatsApp</h3>
            <p>{clinic.whatsappNumber}</p>
          </div>
        </a>
      </div>
    </div>
  </div>
</section>
