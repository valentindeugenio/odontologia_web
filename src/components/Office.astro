---
import { clinic } from '../data/clinic.js';
---

<section class="office" id="consultorio">
  <div class="container">
    <div class="office-heading">
      <div>
        <span class="section-tag">CONSULTORIO EN CABA</span>
        <h2>Dirección y datos de atención</h2>
      </div>
      <p>Estamos en una ubicación céntrica de la Ciudad de Buenos Aires. Podés abrir el mapa, llamarnos o escribirnos directamente.</p>
    </div>
    <div class="office-layout">
      <div class="map-wrapper">
        <iframe title="Mapa del consultorio en Av. Santa Fe 3069, CABA" src="https://www.google.com/maps?q=Av.%20Santa%20Fe%203069%2C%20CABA&output=embed" loading="lazy" referrerpolicy="no-referrer-when-downgrade" allowfullscreen></iframe>
      </div>
      <div class="contact-grid">
        <a class="contact-card" href={clinic.mapsLink} target="_blank" rel="noopener noreferrer"><span class="contact-icon" aria-hidden="true">📍</span><div><h3>Dirección</h3><p>{clinic.address}</p><small>{clinic.city}</small></div></a>
        <div class="contact-card"><span class="contact-icon" aria-hidden="true">🕒</span><div><h3>Horario de atención</h3><p>{clinic.openingHours}</p><small>{clinic.openingHoursDetail}</small></div></div>
        <a class="contact-card" href={clinic.whatsappLink} target="_blank" rel="noopener noreferrer"><span class="contact-icon" aria-hidden="true">💬</span><div><h3>WhatsApp</h3><p>{clinic.whatsappNumber}</p><small>Escribinos ahora</small></div></a>
        <a class="contact-card" href={clinic.phoneHref}><span class="contact-icon" aria-hidden="true">☎️</span><div><h3>Teléfono</h3><p>{clinic.phone}</p><small>Tocá para llamar</small></div></a>
      </div>
    </div>
  </div>
</section>
