---
import { teamMembers } from '../data/team.js';
---

<section class="team" id="equipo">
  <div class="container team-container">
    <header class="team-heading">
      <span class="section-tag">NUESTRO EQUIPO</span>
      <h2>Experiencia clínica, trato humano</h2>
      <p class="section-description">
        Un equipo que trabaja de manera coordinada, con criterio profesional y una
        atención cercana en cada etapa.
      </p>
    </header>

    <article class="team-showcase">
      <div class="team-showcase-visual" data-group-image="/images/equipo-grupal.png" role="img" aria-label="Espacio preparado para la futura fotografía grupal del equipo"></div>
      <div class="team-showcase-copy">
        <span>ATENCIÓN COORDINADA</span>
        <h3>Un equipo preparado para acompañarte en cada etapa.</h3>
        <p>Profesionales, secretaría y asistencia trabajando de manera integrada para ofrecer una experiencia clara, cercana y cuidada.</p>
      </div>
    </article>

    <div class="team-list">
      {teamMembers.map((member) => (
        <article class="doctor-card">
          <div class="doctor-portrait">
            {member.image ? <img src={member.image} alt={member.alt} loading="lazy" /> : <span class="doctor-placeholder" aria-hidden="true">{member.role}</span>}
          </div>

          <div class="doctor-info">
            <div class="doctor-identity">
              <h3>{member.name}</h3>
            <p class="doctor-registration">{member.role ?? member.registration}</p>
            </div>

            {member.experience && <span class="doctor-experience">{member.experience} de experiencia</span>}
            <p class="doctor-description">{member.description}</p>
          </div>
        </article>
      ))}
    </div>

  </div>
</section>
